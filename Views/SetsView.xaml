<UserControl x:Class="GleemLet.Views.SetsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GleemLet.Views"
             xmlns:vm="clr-namespace:GleemLet.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=vm:SetsViewModel}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="32,28,32,20">
            <StackPanel>
                <TextBlock Text="{Binding SetsTitle}" Style="{StaticResource SectionTitle}" Margin="0"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Search Box -->
                    <Border Grid.Column="0" Background="{DynamicResource Surface}" BorderBrush="{DynamicResource Border}"
                            BorderThickness="1" CornerRadius="8" Margin="0,0,10,0">
                        <Grid>
                            <TextBox x:Name="SearchBox" Style="{StaticResource DarkTextBox}"
                                     BorderThickness="0" Background="Transparent"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                            <StackPanel Orientation="Horizontal" IsHitTestVisible="False" VerticalAlignment="Center" Margin="12,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <materialDesign:PackIcon Kind="Magnify" Width="16" Height="16" Foreground="{DynamicResource Dim}" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding SearchPlaceholder}" Foreground="{DynamicResource Dim}"
                                           FontFamily="Segoe UI" FontSize="13"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- Category Filter -->
                    <ComboBox Grid.Column="1"
          Width="140" Margin="0,0,10,0"
          ItemsSource="{Binding Categories}"
          SelectedItem="{Binding SelectedCategory}"
          Background="#1C1C22"
          Foreground="#E8E8F0"
          BorderBrush="#2E2E3A"
          BorderThickness="1"
          Padding="10,8">
    <ComboBox.Resources>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1C1C22"/>
            <Setter Property="Foreground" Value="#E8E8F0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2E2E3A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </ComboBox.Resources>
</ComboBox>
                    
                    <!-- New Set Button -->
                    <Button Grid.Column="2" Content="{Binding NewSetLabel}"
                            Style="{StaticResource PrimaryButton}" 
                            Command="{Binding NewSetCommand}"/>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- Sets List -->
        <ScrollViewer Grid.Row="1" Margin="32,0,32,32" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding FilteredSets}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Set Card Template -->
                        <Border Margin="0,0,12,12" Width="240" Background="{DynamicResource Surface}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="10" Padding="16" Cursor="Hand">
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource Text}" TextWrapping="Wrap"/>
                                    <Border Background="{DynamicResource Surface2}" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right" VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Category}" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource Teal}"/>
                                    </Border>
                                </Grid>
                                <TextBlock FontSize="11" Foreground="{DynamicResource Dim}" Margin="0,0,0,10">
                                    <Run Text="{Binding Words.Count, Mode=OneWay}"/>
                                    <Run Text=" words"/>
                                </TextBlock>

                                <!-- Progress Bar -->
                                <Border Background="{DynamicResource Surface2}" Height="4" CornerRadius="2">
                                    <Border Background="{DynamicResource Teal}" CornerRadius="2" HorizontalAlignment="Left">
                                        <Border.Width>
                                            <MultiBinding Converter="{StaticResource WidthPercentageConverter}">
                                                <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Border, AncestorLevel=1}"/>
                                                <Binding Path="ProgressPercent"/> 
                                            </MultiBinding>
                                        </Border.Width>
                                    </Border>
                                </Border>
                                <TextBlock Text="{Binding LearnedCount, StringFormat='{}{0} learned'}" FontSize="10" Foreground="{DynamicResource Dim}" Margin="0,4,0,14"/>

                                 <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource GhostButton}" Padding="8,5" Margin="0,0,6,0"
                                            ToolTip="Flashcards"
                                            Command="{Binding DataContext.StartFlashcardsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Cards" Width="18" Height="18" VerticalAlignment="Center"/>
                                    </Button>
                                    <Button Style="{StaticResource GhostButton}" Padding="8,5" Margin="0,0,6,0"
                                            ToolTip="Learn"
                                            Command="{Binding DataContext.StartLearnCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Head" Width="18" Height="18" VerticalAlignment="Center"/>
                                    </Button>
                                    <Button Style="{StaticResource GhostButton}" Padding="8,5"
                                            ToolTip="Test"
                                            Command="{Binding DataContext.StartTestCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="PencilBox" Width="18" Height="18" VerticalAlignment="Center"/>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
