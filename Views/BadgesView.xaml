<UserControl x:Class="GleemLet.Views.BadgesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"              xmlns:local="clr-namespace:GleemLet.Views"
              xmlns:vm="clr-namespace:GleemLet.ViewModels"
              xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=vm:BadgesViewModel}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,32">
            
            <TextBlock Text="Badges" Style="{StaticResource SectionTitle}" Margin="0,0,0,6" FontSize="24"/>
            <TextBlock FontSize="13" Foreground="{DynamicResource Dim}" Margin="0,0,0,24">
                <Run Text="You have earned "/>
                <Run Text="{Binding EarnedCount, Mode=OneWay}" FontWeight="Bold" Foreground="{DynamicResource Teal}"/>
                <Run Text=" of "/>
                <Run Text="{Binding TotalCount, Mode=OneWay}" FontWeight="Bold"/>
                <Run Text=" achievements."/>
            </TextBlock>

            <ItemsControl ItemsSource="{Binding Badges}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="160" Margin="0,0,12,12" BorderThickness="1" CornerRadius="10" Padding="16">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource Surface}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
                                    <Setter Property="Opacity" Value="0.45"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Earned}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource TealBg}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource Teal}"/>
                                            <Setter Property="Opacity" Value="1.0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="{Binding Icon}" Width="48" Height="48" HorizontalAlignment="Center" Margin="0,0,0,8">
                                    <materialDesign:PackIcon.Style>
                                        <Style TargetType="materialDesign:PackIcon">
                                            <Setter Property="Foreground" Value="{DynamicResource Dim}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Earned}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource Yellow}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </materialDesign:PackIcon.Style>
                                </materialDesign:PackIcon>
                                <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource Muted}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Earned}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource Teal}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding Description}" FontSize="10" Foreground="{DynamicResource Dim}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding EarnedDate, StringFormat='{}{0:MMM d}'}" FontSize="10" Foreground="{DynamicResource Teal}" HorizontalAlignment="Center" Margin="0,4,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Earned}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
