<UserControl x:Class="GleemLet.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GleemLet.Views"
             xmlns:vm="clr-namespace:GleemLet.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=vm:HomeViewModel}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,32">
            
            <!-- Hero Card -->
            <Border Background="{DynamicResource TealBg}" BorderBrush="{DynamicResource Teal2}" BorderThickness="1" CornerRadius="12" Margin="0,0,0,24" Padding="24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding WelcomeMessage}" FontSize="13" Foreground="{DynamicResource Teal}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Goal}" FontSize="22" Foreground="{DynamicResource Text}" FontWeight="Bold" Margin="0,4,0,6" TextWrapping="Wrap"/>
                        <TextBlock Text="Consistency is the key to mastering a language." FontSize="13" Foreground="{DynamicResource Muted}"/>
                        
                        <StackPanel Margin="0,16,0,0">
                            <Border Background="#1E1E24" Height="8" CornerRadius="4">
                                <Border Background="{DynamicResource Yellow}" Height="8" CornerRadius="4" HorizontalAlignment="Left">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource WidthPercentageConverter}">
                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Border, AncestorLevel=2}"/>
                                            <Binding Path="XpPercent"/>
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                            </Border>
                            <TextBlock FontSize="11" Foreground="{DynamicResource Dim}" Margin="0,5,0,0">
                                <Run Text="Level "/>
                                <Run Text="{Binding Level, Mode=OneWay}"/>
                                <Run Text="  ·  "/>
                                <Run Text="{Binding Xp, StringFormat='{}{0} XP'}"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <local:StatBox Icon="BookMultiple" Value="{Binding TotalWords}" Label="{Binding WordsLabel}" Margin="0,0,0,8" MainColor="{DynamicResource Blue}"/>
                        <local:StatBox Icon="CheckDecagram" Value="{Binding TotalLearned}" Label="{Binding LearnedLabel}" Margin="0,0,0,8" MainColor="{DynamicResource Teal}"/>
                        <local:StatBox Icon="Fire" Value="{Binding Streak}" Label="{Binding StreakLabel}" Margin="0,0,0,8" MainColor="{DynamicResource Yellow}"/>
                        <local:StatBox Icon="Star" Value="{Binding Level}" Label="{Binding LevelLabel}" MainColor="{DynamicResource Purple}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Daily Goal Section -->
            <TextBlock Text="{Binding DailyGoalTitle}" Style="{StaticResource SectionTitle}" Margin="0,0,0,12"/>
            <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="10" Padding="18,14" Margin="0,0,0,24">
                <StackPanel>
                    <Grid>
                        <TextBlock Text="Today's Progress" FontSize="13" Foreground="{DynamicResource Text}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding DailyGoalPercent, StringFormat='{}{0:P0}'}" FontSize="13" Foreground="{DynamicResource Teal}" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>
                    <TextBlock Text="{Binding TodayProgressText}" FontSize="11" Foreground="{DynamicResource Muted}" Margin="0,4,0,8" VerticalAlignment="Center"/>
                    <Border Background="{DynamicResource Surface2}" Height="8" CornerRadius="4">
                        <Border Height="8" CornerRadius="4" HorizontalAlignment="Left">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#4FAC82" Offset="0"/>
                                    <GradientStop Color="#5CDEB5" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Width>
                                <MultiBinding Converter="{StaticResource WidthPercentageConverter}">
                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Border, AncestorLevel=2}"/>
                                    <Binding Path="DailyGoalPercent"/>
                                </MultiBinding>
                            </Border.Width>
                        </Border>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Recent Sets Header -->
            <Grid Margin="0,0,0,16">
                <TextBlock Text="{Binding RecentSetsTitle}" Style="{StaticResource SectionTitle}" Margin="0" VerticalAlignment="Center"/>
                <Button Content="{Binding ViewAllLabel}" Style="{StaticResource GhostButton}" HorizontalAlignment="Right" Command="{Binding GoToSetsCommand}"/>
            </Grid>
            
            <!-- Recent Sets List -->
            <ItemsControl ItemsSource="{Binding RecentSets}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,12,12" Width="240" Background="{DynamicResource Surface}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="10" Padding="16">
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource Text}" TextWrapping="Wrap"/>
                                    <Border Background="{DynamicResource Surface2}" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right" VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Category}" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource Teal}"/>
                                    </Border>
                                </Grid>
                                <TextBlock FontSize="11" Foreground="{DynamicResource Dim}" Margin="0,0,0,10">
                                    <Run Text="{Binding Words.Count, Mode=OneWay}"/>
                                    <Run Text=" words"/>
                                </TextBlock>

                                <!-- Progress Bar -->
                                <Border Background="{DynamicResource Surface2}" Height="4" CornerRadius="2">
                                    <Border Background="{DynamicResource Teal}" CornerRadius="2" HorizontalAlignment="Left">
                                        <Border.Width>
                                            <MultiBinding Converter="{StaticResource WidthPercentageConverter}">
                                                <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Border, AncestorLevel=1}"/>
                                                <Binding Path="ProgressPercent"/> 
                                            </MultiBinding>
                                        </Border.Width>
                                    </Border>
                                </Border>
                                <TextBlock Text="{Binding LearnedCount, StringFormat='{}{0} learned'}" FontSize="10" Foreground="{DynamicResource Dim}" Margin="0,4,0,14"/>

                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource GhostButton}" Padding="8,5" Margin="0,0,6,0"
                                            ToolTip="Flashcards"
                                            Command="{Binding DataContext.StartFlashcardsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Cards" Width="18" Height="18" VerticalAlignment="Center"/>
                                    </Button>
                                    <Button Style="{StaticResource GhostButton}" Padding="8,5" Margin="0,0,6,0"
                                            ToolTip="Learn"
                                            Command="{Binding DataContext.StartLearnCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Head" Width="18" Height="18" VerticalAlignment="Center"/>
                                    </Button>
                                    <Button Style="{StaticResource GhostButton}" Padding="8,5"
                                            ToolTip="Test"
                                            Command="{Binding DataContext.StartTestCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="PencilBox" Width="18" Height="18" VerticalAlignment="Center"/>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Recent Activity -->
            <TextBlock Text="{Binding RecentActivityTitle}" Style="{StaticResource SectionTitle}" Margin="0,10,0,16"/>
            <ItemsControl ItemsControl.ItemsSource="{Binding RecentSessions}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding SetName}" FontSize="13" Foreground="{DynamicResource Text}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Date, StringFormat='{}{0:MMM d, yyyy h:mm tt}'}" FontSize="11" Foreground="{DynamicResource Dim}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="{DynamicResource TealBg}" CornerRadius="6" Padding="8,4" VerticalAlignment="Center">
                                    <TextBlock Foreground="{DynamicResource Teal}" FontWeight="Bold" FontSize="12">
                                        <Run Text="{Binding Accuracy, StringFormat='{}{0:F0}%'}"/>
                                        <Run Text=" · "/>
                                        <Run Text="{Binding Correct, Mode=OneWay}"/>
                                        <Run Text="/"/>
                                        <Run Text="{Binding Total, Mode=OneWay}"/>
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
