*.tlh
*.tmp
*.tmp_proj
*_wpftmp.csproj
*.log
*.vsdeps
*.vspscc
*.vssscc
.builds
*.pidb
*.svclog
*.scc

# Chutzpah Test files
_Chutzpah*

# Visual C++ cache files
ipch/
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb

# Visual Studio profiler
*.psess
*.vsp
*.vspx
*.sap

# Visual Studio Trace Files
*.e2e

# GleemLet Temporary Files
app_run_result.txt
build_error_final.txt
crash.log

# AI/Agent temporary files
.antigravity*
.gemini/

# TFS 2012 Local Workspace
$tf/

# Guidance Automation Toolkit
*.recipes
*.visualstudiocache

# SWIG
*_wrap.c
*_wrap.cpp
*_wrap.cxx
*_wrap.o
*_wrap.obj

# Auto-Generated XML Documentation
*.xml

# StyleCop
StyleCopReport.xml

# CodeRush personal settings
.cr/personal

# Python Tools for Visual Studio (PTVS)
__pycache__/
*.pyc

# Cake - Uncomment if you are using it
# tools/**
# !tools/packages.config

# DotNetCore
project.lock.json
project.assets.json
*.nuget.props
*.nuget.targets
.nupkg
.snupkg

# Rider
.idea/
*.sln.iml

# Resharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# SonarQube
.sonarqube

# VS Code
.vscode/

# Local History for Visual Studio
.localhistory/

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msu
*.msp
*.lnk

# Publish output (large files)
publish/
*.exe